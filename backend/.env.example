# ─── 한국투자증권 (KIS) API ──────────────────────────────────────────────────
APP_KEY=your_kis_app_key_here
APP_SECRET=your_kis_app_secret_here
# 모의투자 여부 (true / false)
KIS_MOCK=false

# ─── MySQL DB ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=seedup_db

# ─── LLM (CrewAI / LiteLLM) ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# 사용할 LLM 모델 (기본값: openai/gpt-4o-mini)
MANAGER_LLM_MODEL=openai/gpt-4o-mini

# ─── 경로 설정 (기본값: 자동 감지, 변경 필요 시만 설정) ──────────────────────
# CREWAI_ROOT=/absolute/path/to/seedup_work_merge
# FIN_MODEL_DIR=/absolute/path/to/fin_structured_model
# SIGNAL_PACK_PATH=/absolute/path/to/stock_direction_model/data/outputs/signal_pack/signal_pack_latest.csv
