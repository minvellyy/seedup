# ─── 한국투자증권 (KIS) API ──────────────────────────────────────────────────
APP_KEY=your_kis_app_key_here
APP_SECRET=your_kis_app_secret_here
# 모의투자 여부 (true / false)
KIS_MOCK=false

# ─── MySQL DB ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=seedup_db

# ─── LLM (CrewAI / LiteLLM) ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# 사용할 LLM 모델 (기본값: openai/gpt-4o-mini)
MANAGER_LLM_MODEL=openai/gpt-4o-mini

# ─── 경로 설정 (기본값: 자동 감지, 변경 필요 시만 설정) ──────────────────────
# CREWAI_ROOT=/absolute/path/to/seedup_work_merge
# FIN_MODEL_DIR=/absolute/path/to/fin_structured_model
# SIGNAL_PACK_PATH=/absolute/path/to/stock_direction_model/data/outputs/signal_pack/signal_pack_latest.csv

# ─── 뉴스 RAG 파이프라인 ────────────────────────────────────────────────────
# 네이버 검색 API (https://developers.naver.com/apps)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
# OpenAI 임베딩 / 분석 모델 (기본값 사용 시 생략 가능)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# ChromaDB 저장 경로 (기본값: backend/chroma_db)
# CHROMA_PATH=./chroma_db
