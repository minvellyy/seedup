# ─── LLM (LiteLLM / OpenAI) ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# 기본값: openai/gpt-4o-mini
MANAGER_LLM_MODEL=openai/gpt-4o-mini
# 뉴스 분석 LLM (기본값: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ─── DB (manager_agent 내부 도구에서 직접 접근 시) ───────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=seedup_db

# ─── 뉴스 수집 (Naver Search API) ───────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ─── 뉴스 RAG (ChromaDB) ────────────────────────────────────────────────────
# 기본값: backend/news_model/chroma_db (자동 설정, 변경 시에만 지정)
# CHROMA_PATH=/absolute/path/to/chroma_db
