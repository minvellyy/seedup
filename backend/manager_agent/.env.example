# ─── LLM (LiteLLM / OpenAI) ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# 기본값: openai/gpt-4o-mini
MANAGER_LLM_MODEL=openai/gpt-4o-mini

# ─── DB (manager_agent 내부 도구에서 직접 접근 시) ───────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=seedup_db
